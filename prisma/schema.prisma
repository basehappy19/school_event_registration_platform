generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

model AdminUser {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  avatar    String?
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
}

enum LoginStatus {
  SUCCESS
  FAILED
}

model AdminLoginLog {
  id           Int         @id @default(autoincrement())
  emailAttempt String
  ipAddress    String?
  userAgent    String?
  status       LoginStatus
  failureReason String?
  createdAt    DateTime    @default(now())
}

model StudentProfile {
  studentId  String         @id
  nationalId String
  prefix     String
  firstName  String
  lastName   String
  grade      String
  room       String
  number     String
  email      String?        @unique

  registrations Registration[]
}

model Project {
  id                    String   @id @default(uuid())
  title                 String
  description           String?
  posterUrl             String?
  
  // Existing fields (can be used for general activity duration if needed, but we will rely on specific fields below)
  startDate             DateTime
  endDate               DateTime
  
  // Visibility setting
  isPublished           Boolean  @default(false)
  order                 Int      @default(0)

  // Registration settings
  isRegistrationOpen    Boolean  @default(false)
  registrationStartDate DateTime?
  registrationEndDate   DateTime?

  // Announcement settings
  isAnnouncementOpen    Boolean  @default(false)
  announcementStartDate DateTime?
  announcementEndDate   DateTime?

  // Activity Details (for PDF/Export header)
  activityDate          DateTime?
  activityStartTime     DateTime?
  activityEndTime       DateTime?
  activityLocation      String?  // e.g. "ห้องประชุม 1"

  quotas        ProjectQuota[]
  formFields    FormField[]
  registrations Registration[]
}

model ProjectQuota {
  id               Int    @id @default(autoincrement())
  projectId        String
  grade            String
  capacity         Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, grade])
}

enum FieldType {
  SHORT_TEXT
  DROPDOWN
  CHECKBOX
}

model FormField {
  id         Int       @id @default(autoincrement())
  projectId  String
  label      String
  type       FieldType
  options    String?   // JSON string or comma-separated
  isRequired Boolean   @default(false)

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  answers FormAnswer[]
}

model FormAnswer {
  id             String @id @default(cuid())
  registrationId String
  fieldId        Int
  value          String // Stored as a string, parse if needed based on FormField type

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  field        FormField    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

enum RegistrationStatus {
  APPROVED
  WAITLISTED
  REJECTED
  CANCELLED
}

model Registration {
  id              String             @id @default(cuid())
  projectId       String
  studentId       String
  status          RegistrationStatus @default(WAITLISTED)
  cancelReason    String?

  createdAt DateTime @default(now())

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  answers        FormAnswer[]
  
  @@unique([projectId, studentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  adminEmail String?
  studentId  String?
  projectId  String?
  ipAddress  String?
  userAgent  String?
  payload    String?
  createdAt  DateTime @default(now())
}

model RegistrationLog {
  id             String   @id @default(cuid())
  action         String   // e.g. "REGISTER", "CANCEL", "ADMIN_DELETE", "ADMIN_APPROVE", "ADMIN_REJECT", "ADMIN_WAITLIST", "AUTO_PROMOTE"
  projectId      String
  projectTitle   String?
  studentId      String
  studentName    String?
  gradeRoom      String?
  previousStatus String?
  newStatus      String?
  performedBy    String   // e.g. "STUDENT", "ADMIN:xxx@email.com", "SYSTEM"
  ipAddress      String?
  userAgent      String?
  details        String?
  createdAt      DateTime @default(now())
}

model ProjectEditLog {
  id           Int      @id @default(autoincrement())
  projectId    String
  projectTitle String
  adminEmail   String
  action       String   // e.g. "CREATE_PROJECT", "UPDATE_PROJECT", "TOGGLE_PUBLISH", "DELETE_PROJECT"
  changes      String   // JSON diff string
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
}
